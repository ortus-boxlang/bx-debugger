{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "BoxDebugger",
            "request": "launch",
            "mainClass": "ortus.boxlang.bxdebugger.BoxDebugger",
            "projectName": "bx-debugger",
            "args": "9898"
        },
        {
            "type": "java",
            "name": "BoxDebugger - Local JARs",
            "request": "launch",
            "mainClass": "ortus.boxlang.bxdebugger.BoxDebugger",
            "args": "9898",
            "classPaths": [
                "${workspaceFolder}/build/libs/*",
                "${workspaceFolder}/../boxlang/build/libs/*"
            ]
        },
        {
            "type": "boxlang",
            "name": "BoxDebugger - Run BoxLang File",
            "request": "launch",
            "program": "${file}",
            "debugServer": 9898
        },
        {
            "type": "boxlang",
            "name": "BoxDebugger - Remote",
            "request": "attach",
            "debugServer": 9898,
            "serverPort": 9888,
            "localRoot": "C:\\Users\\jacob\\Dev\\ortus-boxlang\\bx-debugger\\docker-test",
            "remoteRoot": "/app"
        },
        {
            "type": "boxlang",
            "name": "Attach to BoxLang Miniserver",
            "request": "attach",
            "debugServer": 9898,
            "serverPort": 5005,
            "program": "${workspaceFolder}/debug-webroot/index.bxm",
            "localRoot": "${workspaceFolder}/debug-webroot",
            "remoteRoot": "${workspaceFolder}/debug-webroot"
        }
    ],
    "compounds": [
        {
            "name": "Debug Miniserver (Full Stack)",
            "configurations": [
                "BoxDebugger - Local JARs"
            ],
            "preLaunchTask": "Start BoxLang Miniserver (Debug)",
            "stopAll": true,
            "presentation": {
                "hidden": false,
                "group": "debug",
                "order": 1
            }
        }
    ]
}
