{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build debugAgentJar",
			"type": "shell",
			"command": "./gradlew.bat",
			"args": [
				"debugAgentJar"
			],
			"isBackground": false,
			"problemMatcher": [
				"$gradle"
			],
			"group": "build"
		},
		{
			"label": "Test AttachRunningProcess",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$env:BOX_DEBUGGER_ATTACH_TEST='1'; ./gradlew.bat test --tests ortus.boxlang.moduleslug.AttachRunningProcessTest"
			],
			"isBackground": false,
			"group": "test"
		}
	]
}